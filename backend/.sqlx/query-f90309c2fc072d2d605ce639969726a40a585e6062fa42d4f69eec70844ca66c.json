{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                d.id,\n                d.year,\n                d.teacher,\n                d.exam_type,\n                d.is_answer,\n                d.num,\n                s.id AS subject_id,\n                s.major_id,\n                s.grade,\n                s.term,\n                m.faculty_id\n            FROM documents AS d\n                INNER JOIN subjects AS s ON s.id = d.subject_id\n                INNER JOIN majors AS m ON m.id = s.major_id\n            WHERE d.id = $1\n        ",
